{
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
        "baseUrl": ".",
        "paths": {
            "~/*": ["src/*"]
        },
        "noEmit": true,
        "allowImportingTsExtensions": true,
        "jsx": "react-jsx",
        "moduleResolution": "bundler",
        "module": "ESNext",
        "lib": ["ES2022", "DOM", "DOM.Iterable"]
    },
    "include": ["src"],
    "exclude": ["cypress", "node_modules", "dist"]
}
